# ============================================
# MedicTurn — Environment Variables
# ============================================

# Database
POSTGRES_USER=medicturn
POSTGRES_PASSWORD=medicturn_secret_2024
POSTGRES_DB=medicturn
DATABASE_URL=postgresql://medicturn:medicturn_secret_2024@postgres:5432/medicturn

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Backend
BACKEND_PORT=4000
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_APP_NAME=MedicTurn

# Meta WhatsApp (stubs — fill when credentials are ready)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
META_VERIFY_TOKEN=medicturn_webhook_verify_token

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
